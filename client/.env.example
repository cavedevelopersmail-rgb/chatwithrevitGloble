# ─────────────────────────────────────────────────────────────────────────
#  Compliance House / Rivet AI — Client (Vite) environment variables
#
#  Copy this file to `.env` and fill in real values:
#      cp client/.env.example client/.env
#
#  Vite only exposes vars prefixed with VITE_ to the browser bundle.
#
#  Production deployment:  https://chatwith.rivetglobal.net
# ─────────────────────────────────────────────────────────────────────────


# ── API base URL ───────────────────────────────────────────────────────
# The React app calls the API at `${VITE_API_URL}/auth`, `${VITE_API_URL}/chat`,
# `${VITE_API_URL}/conversations`, and `${VITE_API_URL}/projects`.
#
# Development : leave as "/api" — Vite proxies /api -> http://localhost:8000
# Production  : leave as "/api" — Express serves the React build from the same
#               origin (chatwith.rivetglobal.net), so a relative URL works.
#               Only override this if you ever split the API onto its own
#               domain, e.g. VITE_API_URL=https://api.rivetglobal.net/api
VITE_API_URL=/api


# ── Google OAuth Client ID (browser-side) ──────────────────────────────
# Used by "Continue with Google" on the /login page. This is the SAME value
# as the server's GOOGLE_CLIENT_ID — the Client ID is public by design,
# only the Client Secret must stay private.
#
# vite.config.js auto-injects this from a GOOGLE_CLIENT_ID variable that's
# set in the same shell/process running Vite. On Replit it's pulled from
# the Secrets pane automatically, so locally you usually don't set it here.
# Set it explicitly only if your local shell doesn't export GOOGLE_CLIENT_ID.
#
# Format: <number>-<hash>.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com


# ─────────────────────────────────────────────────────────────────────────
#  Google Cloud Console — OAuth 2.0 Client ID config for production
#  (Set these in https://console.cloud.google.com/apis/credentials)
#
#  Authorized JavaScript origins:
#    https://chatwith.rivetglobal.net
#    http://localhost:5000                   (local dev)
#
#  Authorized redirect URIs:
#    https://chatwith.rivetglobal.net/login
#    http://localhost:5000/login             (local dev)
# ─────────────────────────────────────────────────────────────────────────
