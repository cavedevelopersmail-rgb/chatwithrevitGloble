# ─────────────────────────────────────────────────────────────────────────
#  Compliance House / Rivet AI — Client (Vite) environment variables
#
#  Copy this file to `.env` and fill in real values:
#      cp client/.env.example client/.env
#
#  Vite only exposes vars prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────


# Base URL the React app uses to reach the API.
# Leave as "/api" in development — Vite proxies /api -> http://localhost:8000.
# In production, set to your full API origin, e.g. https://api.example.com/api
# VITE_API_URL=/api

# Google OAuth Client ID exposed to the browser for "Continue with Google".
# NOTE: vite.config.js injects this from a GOOGLE_CLIENT_ID variable that
# must be set in the SAME shell/process that runs `npm run dev` or the Vite
# build. On Replit it comes from the Secrets pane automatically. Locally,
# either export GOOGLE_CLIENT_ID before running Vite, or set the line below.
VITE_GOOGLE_CLIENT_ID=
