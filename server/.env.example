# ─────────────────────────────────────────────────────────────────────────
#  Compliance House / Rivet AI — Server environment variables
#
#  Copy this file to `.env` and fill in real values:
#      cp server/.env.example server/.env
#
#  On Replit, do NOT commit a real .env — secrets live in the Secrets pane.
#  Locally, the .env file is loaded automatically by dotenv on startup.
#
#  Production deployment:  https://chatwith.rivetglobal.net
# ─────────────────────────────────────────────────────────────────────────


# ── REQUIRED ────────────────────────────────────────────────────────────

# MongoDB connection string. Used by server/config/database.js.
# Examples:
#   Local dev   : mongodb://localhost:27017/rivetai
#   Production  : mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/rivetai
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rivetai

# Secret used to sign and verify JWT auth tokens. Use a long random string.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT: rotating this value invalidates every existing user session.
JWT_SECRET=replace-with-a-long-random-string

# Google Gemini API key. Powers BOTH the main "Compliance House" chat
# (server/controllers/chatController.js) and the source-grounded Projects
# chat (server/controllers/projectController.js).
# Get a key at: https://aistudio.google.com/app/apikey
# Format: starts with AIzaSy...
GEMINI_API_KEY=your-gemini-api-key-here


# ── OPTIONAL ────────────────────────────────────────────────────────────

# Port the API listens on. Defaults to 8000. In production behind a
# reverse proxy / Replit Deployment this is usually left unset.
PORT=8000

# Override the Gemini model. Defaults to gemini-2.5-flash if unset.
# Other valid values: gemini-2.5-pro (slower, smarter), gemini-2.0-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Alternative name accepted in place of GEMINI_API_KEY (whichever is set wins).
# Useful if a host/platform provisions Google credentials under this name.
# GOOGLE_API_KEY=

# Google OAuth Client ID. Required ONLY if you want "Continue with Google"
# sign-in. Without it, email/password login still works.
# Create one at: https://console.cloud.google.com/apis/credentials
# Format: <number>-<hash>.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=


# ─────────────────────────────────────────────────────────────────────────
#  Google Cloud Console — OAuth 2.0 Client ID config for production
#  (https://console.cloud.google.com/apis/credentials → your Web client)
#
#  Authorized JavaScript origins:
#    https://chatwith.rivetglobal.net
#    http://localhost:5000                   (local dev)
#
#  Authorized redirect URIs:
#    https://chatwith.rivetglobal.net/login
#    http://localhost:5000/login             (local dev)
#
#  Rules: each box holds exactly one URL. No trailing slashes. No spaces.
#  Origins MUST NOT contain a path. Changes can take a few minutes to apply.
# ─────────────────────────────────────────────────────────────────────────
