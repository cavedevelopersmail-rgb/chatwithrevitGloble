# ─────────────────────────────────────────────────────────────────────────
#  Compliance House / Rivet AI — Server environment variables
#
#  Copy this file to `.env` and fill in real values:
#      cp server/.env.example server/.env
#
#  On Replit, do NOT commit a real .env — secrets live in the Secrets pane.
#  Locally, the .env file is loaded automatically by dotenv on startup.
# ─────────────────────────────────────────────────────────────────────────


# ── REQUIRED ────────────────────────────────────────────────────────────

# MongoDB connection string. Used by server/config/database.js.
# Examples:
#   mongodb://localhost:27017/rivetai
#   mongodb+srv://<user>:<pass>@cluster.mongodb.net/rivetai
MONGODB_URI=mongodb://localhost:27017/rivetai

# Secret used to sign and verify JWT auth tokens. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Google Gemini API key. Powers both the main "Compliance House" chat
# (server/controllers/chatController.js) and the source-grounded Projects chat
# (server/controllers/projectController.js).
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here


# ── OPTIONAL ────────────────────────────────────────────────────────────

# Port the API listens on. Defaults to 8000.
PORT=8000

# Override the Gemini model. Defaults to gemini-2.5-flash.
# Other valid values include: gemini-2.5-pro, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Alternative name accepted in place of GEMINI_API_KEY (whichever is set wins).
# GOOGLE_API_KEY=

# Google OAuth Client ID. Only required if you want "Continue with Google"
# sign-in to work. Without it, email/password login still works fine.
# Create one at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
